# Required: Gemini API key for embeddings, noise filter, re-ranker, and comparison
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Only needed for PDF extraction (LlamaParse)
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# Optional: LlamaParse tier — "cost_effective" (default), "agentic", or "agentic_plus"
# LLAMA_PARSE_TIER=cost_effective
