# Required: Gemini API key for embeddings, noise filter, re-ranker, and comparison
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Only needed for PDF extraction (LlamaParse)
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# Required: Trust the FAISS index to allow loading from local storage.
# If you set this, the index will not be created from scratch for every run.
# DC_TRUST_FAISS_INDEX=1

# Optional: LlamaParse tier — "cost_effective" (default), "agentic", or "agentic_plus"
# LLAMA_PARSE_TIER=cost_effective

# Optional: embedding throughput controls for index builds
# Increase batch size for faster indexing; lower it or increase delay if you hit Gemini quota limits.
# DC_EMBEDDING_BATCH_SIZE=20
# DC_EMBEDDING_BATCH_DELAY=1

# Optional: bounded parallel LLM comparisons per selected Doc 1 section
# DC_COMPARE_CONCURRENCY=3
