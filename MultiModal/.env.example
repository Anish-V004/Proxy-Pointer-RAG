# Google Gemini API Key
GOOGLE_API_KEY=your_gemini_api_key_here

# Adobe PDF Services (for extraction)
ADOBE_CLIENT_ID=your_adobe_client_id_here
ADOBE_CLIENT_SECRET=your_adobe_client_secret_here

# Required: Trust the FAISS index to allow loading from local storage.
# If you set this, the index will not be created from scratch for every run.
# PP_TRUST_FAISS_INDEX=1
